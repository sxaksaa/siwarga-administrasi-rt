        <mxCell id="note" value="&lt;b&gt;Keterangan&lt;/b&gt;&lt;br&gt;PK = Primary Key&amp;nbsp;&amp;nbsp; FK = Foreign Key&amp;nbsp;&amp;nbsp; UK = Unique Key&lt;br&gt;&lt;b&gt;UK gabungan:&lt;/b&gt; TAGIHAN (rumah_id + jenis_iuran_id + periode_tagihan); ALOKASI_PEMBAYARAN (pembayaran_id + tagihan_id).&lt;br&gt;&lt;span style=&quot;color:#52665F;&quot;&gt;Kolom created_at dan updated_at serta tabel teknis Laravel tidak ditampilkan agar ERD tetap ringkas dan fokus pada proses bisnis RT.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=12;fillColor=#F5F8F6;strokeColor=#A8B8B2;dashed=1;fontFamily=Arial;fontSize=12;fontColor=#253D36;" vertex="1" parent="1">
